{
  "name": "kisan-setu-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for Kisan Setu AI (Agri-OS) - RDS PostgreSQL + pgvector, Lambda-ready",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate:db": "ts-node src/db/migrate.ts",
    "migrate:rag": "ts-node src/db/migrations/runMigrations.ts",
    "check:db": "ts-node src/db/checkPgvector.ts",
    "seed:rag": "ts-node src/db/seedRagEmbeddings.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1000.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "pg": "^8.11.5",
    "pg-connection-string": "^2.6.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
